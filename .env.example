# =================================================================
# DeltaCompare Autopilot – Beispiel-Konfiguration
# Kopiere diese Datei nach .env und passe alle Werte an.
# In Produktion (Vercel etc.) setzt du diese Werte als Environment
# Variables in der Hosting-Oberfläche.
# =================================================================

# --- Datenbank --------------------------------------------------------------
# STANDARD: PostgreSQL (Produktion + lokal mit Docker)
# Vercel Postgres:
#   DATABASE_URL="${POSTGRES_PRISMA_URL}"
# Neon / Supabase / eigener Server:
#   DATABASE_URL="postgresql://user:pass@host:5432/deltacompare?sslmode=require"
DATABASE_URL="postgresql://user:pass@localhost:5432/deltacompare?sslmode=disable"
#
# Lokale Entwicklung mit SQLite (Alternative):
#   1. cp prisma/schema.sqlite.prisma prisma/schema.prisma
#   2. DATABASE_URL="file:./dev.db" eintragen
#   3. npx prisma generate && npm run db:push && npm run db:seed

# --- Admin-Zugang ------------------------------------------------------------
# Diese Werte werden beim `npm run db:seed` in die User-Tabelle geschrieben
# (Passwort wird bcrypt-gehashed). Anschließend funktioniert der Login auch,
# wenn die .env-Werte später entfernt werden.
ADMIN_EMAIL="admin@deltacompare.local"
ADMIN_PASSWORD="bitte-mit-starkem-passwort-ersetzen"

# --- Session / JWT -----------------------------------------------------------
# MUSS in Produktion gesetzt und mindestens 32 Zeichen lang sein.
# Generieren z. B. mit: openssl rand -base64 48
AUTH_SECRET="bitte-mit-langem-zufaelligen-string-ersetzen-mindestens-32-zeichen"

# --- Public Site-Konfiguration ----------------------------------------------
NEXT_PUBLIC_SITE_NAME="DeltaCompare"
# In Produktion auf finale Domain umstellen:
# NEXT_PUBLIC_SITE_URL="https://deltacompare.de"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- Tracking (alle optional) ------------------------------------------------
# Skripte werden NUR geladen, wenn der Nutzer im Consent-Banner zustimmt.
# Leere Werte = kein Tracking.
GOOGLE_ANALYTICS_ID=""
GOOGLE_TAG_MANAGER_ID=""
META_PIXEL_ID=""
TIKTOK_PIXEL_ID=""

# --- Monetarisierung (Display Ads / CPC / CPM) ------------------------------
# AdSense lädt nur, wenn Client-ID gesetzt und NEXT_PUBLIC_ENABLE_ADS="true".
# Skripte werden zusätzlich erst nach Consent geladen.
GOOGLE_ADSENSE_CLIENT_ID=""
NEXT_PUBLIC_GOOGLE_ADSENSE_CLIENT_ID=""
NEXT_PUBLIC_ENABLE_ADS="false"

# --- Node-Umgebung -----------------------------------------------------------
# Wird von Hostern (Vercel, Railway etc.) automatisch gesetzt.
# Lokal kannst du es weglassen.
# NODE_ENV="production"
