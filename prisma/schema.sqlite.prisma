// SQLite-Variante des Prisma-Schemas (für lokale Entwicklung).
// Für Produktion: cp prisma/schema.prisma (Postgres) verwenden.
//
// Lokale Nutzung:
//   cp prisma/schema.sqlite.prisma prisma/schema.prisma
//   DATABASE_URL="file:./dev.db" in .env
//   npx prisma generate && npx prisma db push && npm run db:seed

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         String   @default("admin")
  createdAt    DateTime @default(now())
}

model Category {
  id          String          @id @default(cuid())
  name        String
  slug        String          @unique
  description String
  icon        String          @default("Tag")
  status      String          @default("active")
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  offers      Offer[]
  comparisons ComparisonPage[]
  cpcOffers   CpcOffer[]
}

model Offer {
  id                  String       @id @default(cuid())
  name                String
  slug                String       @unique
  categoryId          String
  category            Category     @relation(fields: [categoryId], references: [id])
  network             String
  affiliateLink       String
  trackingId          String       @default("")
  commissionType      String       @default("Sale")
  estimatedCommission String       @default("")
  shortDescription    String
  longDescription     String
  advantages          String       @default("")
  disadvantages       String       @default("")
  priceNote           String       @default("")
  rating              Float        @default(4.0)
  logoUrl             String       @default("")
  buttonText          String       @default("Zum Anbieter")
  status              String       @default("active")
  isFeatured          Boolean      @default(false)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  clicks              ClickEvent[]
}

model ComparisonPage {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  categoryId      String
  category        Category @relation(fields: [categoryId], references: [id])
  seoTitle        String
  metaDescription String
  intro           String
  content         String
  faq             String
  offerSlugs      String   @default("")
  status          String   @default("active")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ClickEvent {
  id        String   @id @default(cuid())
  offerId   String
  offer     Offer    @relation(fields: [offerId], references: [id])
  pageSlug  String   @default("")
  referrer  String   @default("")
  userAgent String   @default("")
  device    String   @default("")
  ipHash    String   @default("")
  createdAt DateTime @default(now())

  @@index([offerId])
  @@index([createdAt])
}

model RevenueImport {
  id          String   @id @default(cuid())
  network     String
  date        DateTime
  clicks      Int      @default(0)
  leads       Int      @default(0)
  sales       Int      @default(0)
  revenue     Float    @default(0)
  csvFileName String   @default("")
  createdAt   DateTime @default(now())
}

model MarketingDraft {
  id        String   @id @default(cuid())
  type      String
  platform  String
  title     String
  content   String
  targetUrl String   @default("")
  status    String   @default("draft")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdCampaignDraft {
  id              String   @id @default(cuid())
  platform        String
  campaignName    String
  targetUrl       String
  audience        String   @default("")
  keywords        String   @default("")
  headlines       String   @default("")
  descriptions    String   @default("")
  suggestedBudget String   @default("")
  riskNote        String   @default("")
  status          String   @default("draft")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Settings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdNetwork {
  id          String        @id @default(cuid())
  name        String
  type        String        @default("OTHER")
  status      String        @default("active")
  publisherId String        @default("")
  notes       String        @default("")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  placements  AdPlacement[]
}

model AdPlacement {
  id            String         @id @default(cuid())
  name          String
  slug          String         @unique
  placementType String         @default("IN_CONTENT")
  adType        String         @default("DISPLAY")
  networkId     String?
  network       AdNetwork?     @relation(fields: [networkId], references: [id])
  codeSnippet   String         @default("")
  isActive      Boolean        @default(false)
  showOnMobile  Boolean        @default(true)
  showOnDesktop Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  clicks        AdClick[]
  impressions   AdImpression[]
}

model CpcOffer {
  id            String    @id @default(cuid())
  name          String
  slug          String    @unique
  categoryId    String?
  category      Category? @relation(fields: [categoryId], references: [id])
  network       String    @default("Direkt")
  cpcRate       Float     @default(0)
  targetUrl     String
  affiliateLink String    @default("")
  trackingId    String    @default("")
  description   String    @default("")
  status        String    @default("active")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  clicks        AdClick[]
}

model AdClick {
  id          String       @id @default(cuid())
  placementId String?
  placement   AdPlacement? @relation(fields: [placementId], references: [id])
  cpcOfferId  String?
  cpcOffer    CpcOffer?    @relation(fields: [cpcOfferId], references: [id])
  pageSlug    String       @default("")
  referrer    String       @default("")
  userAgent   String       @default("")
  device      String       @default("")
  ipHash      String       @default("")
  createdAt   DateTime     @default(now())

  @@index([createdAt])
}

model AdImpression {
  id          String      @id @default(cuid())
  placementId String
  placement   AdPlacement @relation(fields: [placementId], references: [id])
  pageSlug    String      @default("")
  device      String      @default("")
  createdAt   DateTime    @default(now())

  @@index([createdAt])
}

model MonetizationReport {
  id                        String   @id @default(cuid())
  date                      DateTime
  impressions               Int      @default(0)
  adClicks                  Int      @default(0)
  affiliateClicks           Int      @default(0)
  leads                     Int      @default(0)
  sales                     Int      @default(0)
  estimatedCpcRevenue       Float    @default(0)
  estimatedCpmRevenue       Float    @default(0)
  estimatedAffiliateRevenue Float    @default(0)
  totalEstimatedRevenue     Float    @default(0)
  createdAt                 DateTime @default(now())
}
